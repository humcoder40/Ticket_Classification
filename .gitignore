# =============================================================================
# Complaint Classification System — .gitignore
# =============================================================================
# Copy this file to the repo root and rename it to:  .gitignore
# (Keep .env.example in git — do NOT commit .env)
# =============================================================================

# --- Secrets & local config ---
.env
.env.local
.env.*.local
*.pem
*.key
secrets/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ---
.venv/
venv/
ENV/
env/
.envrc

# --- Jupyter Notebook ---
.ipynb_checkpoints/
*/.ipynb_checkpoints/
profile_default/
ipython_config.py

# --- Testing / coverage ---
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
coverage.xml
*.cover
*.py,cover
.hypothesis/

# --- Type checkers / linters ---
.mypy_cache/
.dmypy.json
dmypy.json
.ruff_cache/
.pytype/

# --- Flask ---
instance/
.webassets-cache

# --- Machine learning artifacts (large — regenerate via training) ---
models/
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx
*.safetensors

# BERT / Hugging Face saved models (keep code; ignore weights)
bert_model_product/
bert_model_issue/
**/checkpoint-*/
runs/
logs/
mlruns/
wandb/

# Hugging Face & PyTorch caches (re-downloaded automatically)
.cache/
.huggingface/
transformers_cache/

# --- Dataset (large — add separately or use Git LFS if needed) ---
complaints-*.json
*.csv
*.parquet
data/
datasets/
raw/

# --- OS & editor ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini

.vscode/
!.vscode/extensions.json
!.vscode/settings.json.example
.idea/
*.swp
*.swo
*~
.project
.classpath
.settings/

# --- Cursor / local tooling ---
.cursor/
*.log

# --- Windows ---
$RECYCLE.BIN/

# --- Optional: keep these IN git (do not ignore) ---
# !.env.example
# !requirements.txt
# !app.py
# !train_bert_models.py
# !train_classification_model.ipynb
